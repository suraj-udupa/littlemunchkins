# === Database (injected by Railway Postgres plugin) ===
DATABASE_URL=postgresql://user:password@host:5432/dbname

# === Railway Storage Bucket (injected when bucket is linked to api service) ===
BUCKET_NAME=littlemunchkins-media
BUCKET_ENDPOINT=https://storage.railway.app
BUCKET_ACCESS_KEY_ID=your_access_key_id
BUCKET_SECRET_ACCESS_KEY=your_secret_access_key

# === Anthropic Claude ===
ANTHROPIC_API_KEY=sk-ant-...

# === OpenAI Whisper (audio transcription) ===
OPENAI_API_KEY=sk-...

# === Clerk (auth) ===
CLERK_SECRET_KEY=sk_live_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# === Frontend → Backend ===
NEXT_PUBLIC_API_URL=http://localhost:8080

# === Local dev only: MinIO (stands in for Railway Bucket) ===
# BUCKET_ENDPOINT=http://localhost:9000
# BUCKET_ACCESS_KEY_ID=minioadmin
# BUCKET_SECRET_ACCESS_KEY=minioadmin
